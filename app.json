{
  "expo": {
    "name": "d.ai.ly",
    "slug": "daily-ai-app",
    "version": "1.3.6",
    "description": "d.ai.ly - Your daily AI-powered productivity companion for tasks, finances, and time management",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "daily",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daily.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access for AI features",
        "NSMicrophoneUsageDescription": "Microphone access for meeting scheduling"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.daily.ai",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "AddExpenseWidget",
              "label": "Add Expense",
              "description": "Quickly log a new expense",
              "minWidth": "110dp",
              "minHeight": "40dp",
              "targetCellWidth": 2,
              "targetCellHeight": 1,
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/widget-previews/addexpensewidget_preview.png"
            },
            {
              "name": "UpcomingTasksWidget",
              "label": "Tasks & Reminders",
              "description": "Your upcoming tasks and reminders",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/widget-previews/upcomingtaskswidget_preview.png"
            },
            {
              "name": "UpcomingMeetingsWidget",
              "label": "Upcoming Meetings",
              "description": "Your next scheduled meetings",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/widget-previews/upcomingmeetingswidget_preview.png"
            },
            {
              "name": "FinancialOverviewWidget",
              "label": "Financial Overview",
              "description": "This month's income, spending, and budget",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/widget-previews/financialoverviewwidget_preview.png"
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          },
          "android": {
            "minSdkVersion": 26,
            "ndkVersion": "27.0.12077973"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7933176628735047~1170477984"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6eb97e95-86cc-407b-96ab-eb37e279b722"
      }
    },
    "owner": "priyasunnam"
  }
}
